{
  "name": "mango-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "React + Vite frontend for Mango, embedded by the Go binary",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/check-react-outputs.mjs",
    "typecheck": "tsc --noEmit",
    "check": "node scripts/check-react-outputs.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "@vitejs/plugin-react": "4.4.1",
    "typescript": "5.8.3",
    "vite": "6.3.3"
  }
}
