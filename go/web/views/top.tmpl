<!DOCTYPE html>
<html>

  {{ template "head" . }}

  <body>
    <!-- Mobile top bar (small screens only) -->
    <div class="uk-position-top uk-hidden@m">
      <div class="uk-navbar-container mango-navbar" uk-navbar>
        <div class="uk-navbar-left">
          <div class="uk-navbar-toggle" uk-navbar-toggle-icon uk-toggle="target: #mobile-nav"></div>
        </div>
        <div class="uk-navbar-center">
          <a class="uk-navbar-item uk-logo" href="{{.BaseURL}}"><img src="{{.BaseURL}}img/icons/icon.png"></a>
        </div>
      </div>
    </div>

    <!-- Mobile offcanvas nav -->
    <div id="mobile-nav" uk-offcanvas="overlay: true">
      <div class="uk-offcanvas-bar uk-flex uk-flex-column">
        <ul class="uk-nav-parent-icon uk-nav-primary uk-nav-center uk-margin-auto-vertical" uk-nav>
          <li><a href="{{.BaseURL}}" data-i18n="home">主页</a></li>
          <li><a href="{{.BaseURL}}library" data-i18n="library">资料库</a></li>
          <li><a href="{{.BaseURL}}tags" data-i18n="tags">标签</a></li>
          {{if .IsAdmin}}
            <li><a href="{{.BaseURL}}admin" data-i18n="admin">管理员</a></li>
          {{end}}
          <hr uk-divider>
          <li><a onclick="cycleLanguage()" class="lang-toggle" data-i18n-title="language" title="语言"><span class="lang-toggle-label">简</span></a></li>
          <li><a onclick="toggleTheme()" data-i18n="theme_toggle" data-i18n-title="theme_toggle"><i class="fas fa-adjust"></i></a></li>
          <li><a onclick="toggleUIStyle()" data-i18n="ui_style_toggle" data-i18n-title="ui_style_toggle" title="切换UI风格"><i class="fas fa-paint-brush"></i></a></li>
          <li><a href="{{.BaseURL}}logout" data-i18n="logout">登出</a></li>
        </ul>
      </div>
    </div>

    <!-- Desktop sidebar (hidden on mobile) -->
    <nav class="app-sidebar comic-sidebar uk-visible@m">
      <div class="sidebar-logo">
        <a href="{{.BaseURL}}"><img src="{{.BaseURL}}img/icons/icon.png" alt="Mango"></a>
      </div>
      <ul class="sidebar-nav">
        <li><a href="{{.BaseURL}}" data-i18n="home" data-i18n-title="home" title="主页"><i class="fas fa-home"></i><span data-i18n="home">主页</span></a></li>
        <li><a href="{{.BaseURL}}library" data-i18n="library" data-i18n-title="library" title="资料库"><i class="fas fa-book"></i><span data-i18n="library">资料库</span></a></li>
        <li><a href="{{.BaseURL}}tags" data-i18n="tags" data-i18n-title="tags" title="标签"><i class="fas fa-tags"></i><span data-i18n="tags">标签</span></a></li>
        {{if .IsAdmin}}
          <li><a href="{{.BaseURL}}admin" data-i18n="admin" data-i18n-title="admin" title="管理员"><i class="fas fa-cog"></i><span data-i18n="admin">管理员</span></a></li>

        {{end}}
      </ul>
      <div class="sidebar-toggle">
        <button onclick="toggleSidebar()" data-i18n-title="collapse_sidebar" title="收起/展开侧栏">
          <i class="fas fa-chevron-left"></i>
        </button>
      </div>
      <div class="sidebar-footer">
        <a onclick="cycleLanguage()" class="lang-toggle" data-i18n-title="language" title="语言"><span class="lang-toggle-label">简</span></a>
        <a onclick="toggleTheme()" data-i18n-title="theme_toggle" title="切换主题"><i class="fas fa-adjust"></i></a>
        <a onclick="toggleUIStyle()" data-i18n-title="ui_style_toggle" title="切换UI风格"><i class="fas fa-paint-brush"></i></a>
        <a href="{{.BaseURL}}logout" data-i18n-title="logout" title="登出"><i class="fas fa-sign-out-alt"></i></a>
      </div>
    </nav>

    <!-- Main content (single render, responsive) -->
    <div class="app-content">
      <div id="alert"></div>
