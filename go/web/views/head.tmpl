{{define "head"}}
<head>
  <meta charset="utf-8">
  <meta name="X-UA-Compatible" content="IE=edge">
  <title>Mango - {{.PageName}}</title>
  <meta name="description" content="Mango - 漫画服务器和网络阅读器">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <script>
    // FOUC: apply flat/comic + dark markers on <html> before paint.
    // Only load comic fonts when the comic UI style is active.
    (function () {
      var style = localStorage.getItem('ui-style');
      if (style !== 'flat' && style !== 'comic') style = 'comic';
      var theme = localStorage.getItem('theme') || 'system';
      var dark = theme === 'dark' || (theme === 'system' && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
      if (style === 'flat') {
        document.documentElement.classList.add('flat-theme');
        if (dark) document.documentElement.classList.add('flat-theme-dark');
      } else {
        document.documentElement.classList.add('comic-theme');
        if (dark) document.documentElement.classList.add('comic-theme-dark');
        if (!document.getElementById('mango-comic-fonts')) {
          var l = document.createElement('link');
          l.id = 'mango-comic-fonts';
          l.rel = 'stylesheet';
          l.href = 'https://fonts.googleapis.com/css2?family=Bangers&family=Fredoka+One&display=swap';
          document.head.appendChild(l);
        }
      }
      if (dark) document.documentElement.style.background = style === 'flat' ? '#141414' : '';
    })();
  </script>
  <link rel="stylesheet" href="{{.BaseURL}}css/mango.css" />
  <link rel="stylesheet" href="{{.BaseURL}}css/comic-theme.css" />
  <link rel="stylesheet" href="{{.BaseURL}}css/flat-theme.css" />
  <link rel="icon" href="{{.BaseURL}}favicon.ico">
  <link rel="manifest" href="{{.BaseURL}}manifest.json">

  <script src="{{.BaseURL}}js/jquery.min.js"></script>
  <script type="module" src="{{.BaseURL}}js/alpine.min.js"></script>
  <script nomodule src="{{.BaseURL}}js/alpine-ie11.min.js" defer></script>
  <script src="{{.BaseURL}}js/i18n.js"></script>
  <script src="{{.BaseURL}}js/common.js"></script>
</head>
{{end}}