{{define "entry-modal"}}
<div id="modal" class="uk-flex-top mango-modal comic-modal" uk-modal>
  <div class="uk-modal-dialog uk-margin-auto-vertical">
    <button class="uk-modal-close-default" type="button" uk-close></button>
    <div class="uk-modal-header">
      <div>
        <h3 class="uk-modal-title break-word uk-margin-remove-top" id="modal-entry-title"><span></span>
          {{if ne .PageName "home"}}
            {{if .IsAdmin}}
              <a id="modal-edit-btn" class="uk-icon-button" uk-icon="icon:pencil" aria-label="编辑条目" data-i18n-aria-label="edit_entry"></a>
            {{end}}
          {{end}}
          <a id="modal-download-btn" class="uk-icon-button" uk-icon="icon:download" aria-label="下载条目" data-i18n-aria-label="download_entry"></a>
        </h3>
      </div>
      <p class="uk-text-meta uk-margin-remove-bottom break-word" id="path-text"></p>
      <p class="uk-text-meta uk-margin-remove-top" id="pages-text"></p>
    </div>
    <div class="uk-modal-body">
      <p class="modal-section-label" data-i18n="read_section">阅读</p>
      <div class="modal-actions">
      <a id="beginning-btn" class="uk-button uk-button-default comic-btn comic-btn-outline comic-btn-sm" data-i18n="beginning">从头开始</a>
      <a id="continue-btn" class="uk-button uk-button-primary comic-btn comic-btn-primary comic-btn-sm"></a>
      </div>
      <p class="modal-section-label" data-i18n="progress_section">进度</p>
      <div class="modal-actions">
      <button id="read-btn" class="uk-button uk-button-default comic-btn comic-btn-outline comic-btn-sm" data-i18n="mark_read_100">标记为已读 (100%)</button>
      <button id="unread-btn" class="uk-button uk-button-default comic-btn comic-btn-outline comic-btn-sm" data-i18n="mark_unread_0">标记为未读 (0%)</button>
      </div>
    </div>
  </div>
</div>
{{end}}