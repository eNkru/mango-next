{{define "content"}}
<div class="admin-sub-page">
  <form class="mango-form" action="{{.BaseURL}}admin/user/edit" method="post" accept-charset="utf-8">

    <div class="uk-margin">
      <label class="uk-form-label comic-form-label" for="username" data-i18n="username">用户名</label>
      <input class="uk-input comic-input" type="text" name="username" id="username" {{if .Username}} value="{{.Username}}" {{end}} placeholder="请输入用户名" data-i18n-placeholder="enter_username_placeholder">
    </div>

    {{if .NewUser}}
      <div class="uk-margin">
        <label class="uk-form-label comic-form-label" for="password" data-i18n="password">密码</label>
        <div class="form-password-toggle">
          <input class="uk-input comic-input" type="password" name="password" id="password" placeholder="请输入密码" data-i18n-placeholder="enter_password_placeholder">
          <button type="button" class="pw-toggle" onclick="togglePw('password')" aria-label="切换密码可见性" data-i18n-aria-label="toggle_password">
            <i class="fas fa-eye-slash" id="password-icon"></i>
          </button>
        </div>
      </div>
    {{end}}

    <div class="uk-margin">
      <label class="uk-form-label comic-form-label" for="admin">
        <span data-i18n="admin_access">管理员权限</span>
        <input class="uk-checkbox comic-checkbox uk-margin-small-left" type="checkbox" name="admin" id="admin" {{if .Admin}} checked {{end}}>
      </label>
    </div>

    {{if not .NewUser}}
      <div class="uk-margin">
        <button class="uk-button change-pw-btn" type="button" uk-toggle="target: #change-password">
          <i class="fas fa-key uk-margin-small-right"></i> <span data-i18n="change_password">更改密码</span>
        </button>
        <div id="change-password" class="uk-margin" hidden>
          <label class="uk-form-label comic-form-label" for="new-password" data-i18n="new_password">新密码</label>
          <div class="form-password-toggle">
            <input class="uk-input comic-input" type="password" name="password" id="new-password" placeholder="请输入新密码" data-i18n-placeholder="enter_new_password">
            <button type="button" class="pw-toggle" onclick="togglePw('new-password')" aria-label="切换密码可见性" data-i18n-aria-label="toggle_password">
              <i class="fas fa-eye-slash" id="new-password-icon"></i>
            </button>
          </div>
        </div>
      </div>
    {{end}}

    <hr class="form-divider">

    <input type="submit" value="保存" class="uk-button comic-btn comic-btn-primary" data-i18n-value="save">
  </form>
</div>

{{define "scripts"}}
  <script>
    var username;
    var error;
    {{if not .NewUser}}
      username = '{{.Username}}';
    {{end}}
    {{if .Error}}
      error = '{{.Error}}';
    {{end}}

    function togglePw(fieldId) {
      const input = document.getElementById(fieldId);
      const icon = document.getElementById(fieldId + '-icon');
      if (input && icon) {
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';
        icon.className = isPassword ? 'fas fa-eye' : 'fas fa-eye-slash';
      }
    }
  </script>
  <script src="{{.BaseURL}}js/alert.js"></script>
  <script src="{{.BaseURL}}js/user-edit.js"></script>
{{end}}