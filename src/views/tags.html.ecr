<h2 class="page-heading-comic" data-i18n="tags_heading">标签</h2>
<p class="page-subtitle"><%= tags.size %> <span data-i18n="tags_count">标签找到</span></p>

<div>
  <% tags.each do |tag| %>
    <span class="tag-pill comic-tag-pill">
      <a class="uk-link-reset" href="<%= base_url %>tags/<%= tag[:encoded_tag] %>"><%= tag[:tag] %> <small>(<%= tag[:count] %>)</small></a>
    </span>
  <% end %>
</div>
