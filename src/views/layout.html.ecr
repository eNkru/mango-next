<!DOCTYPE html>
<html>

  <%= render_component "head" %>

  <body>
    <!-- Mobile top bar (small screens only) -->
    <div class="uk-position-top uk-hidden@m">
      <div class="uk-navbar-container mango-navbar" uk-navbar>
        <div class="uk-navbar-left">
          <div class="uk-navbar-toggle" uk-navbar-toggle-icon uk-toggle="target: #mobile-nav"></div>
        </div>
        <div class="uk-navbar-center">
          <a class="uk-navbar-item uk-logo" href="<%= base_url %>"><img src="<%= base_url %>img/icons/icon.png"></a>
        </div>
      </div>
    </div>

    <!-- Mobile offcanvas nav -->
    <div id="mobile-nav" uk-offcanvas="overlay: true">
      <div class="uk-offcanvas-bar uk-flex uk-flex-column">
        <ul class="uk-nav-parent-icon uk-nav-primary uk-nav-center uk-margin-auto-vertical" uk-nav>
          <li><a href="<%= base_url %>">主页</a></li>
          <li><a href="<%= base_url %>library">资料库</a></li>
          <li><a href="<%= base_url %>tags">标签</a></li>
          <% if is_admin %>
            <li><a href="<%= base_url %>admin">管理员</a></li>
            <li class="uk-parent">
              <a href="#">下载</a>
              <ul class="uk-nav-sub">
                <li><a href="<%= base_url %>download/plugins">插件</a></li>
                <li><a href="<%= base_url %>admin/downloads">下载管理器</a></li>
                <li><a href="<%= base_url %>admin/subscriptions">订阅管理器</a></li>
              </ul>
            </li>
          <% end %>
          <hr uk-divider>
          <li><a onclick="toggleTheme()"><i class="fas fa-adjust"></i></a></li>
          <li><a href="<%= base_url %>logout">登出</a></li>
        </ul>
      </div>
    </div>

    <!-- Desktop sidebar (hidden on mobile) -->
    <nav class="app-sidebar uk-visible@m">
      <div class="sidebar-logo">
        <a href="<%= base_url %>"><img src="<%= base_url %>img/icons/icon.png" alt="Mango"></a>
      </div>
      <ul class="sidebar-nav">
        <li><a href="<%= base_url %>" title="主页"><i class="fas fa-home"></i><span>主页</span></a></li>
        <li><a href="<%= base_url %>library" title="资料库"><i class="fas fa-book"></i><span>资料库</span></a></li>
        <li><a href="<%= base_url %>tags" title="标签"><i class="fas fa-tags"></i><span>标签</span></a></li>
        <% if is_admin %>
          <li><a href="<%= base_url %>admin" title="管理员"><i class="fas fa-cog"></i><span>管理员</span></a></li>
          <li class="sidebar-divider"></li>
          <li><a href="<%= base_url %>download/plugins" title="插件"><i class="fas fa-puzzle-piece"></i><span>插件</span></a></li>
          <li><a href="<%= base_url %>admin/downloads" title="下载管理器"><i class="fas fa-download"></i><span>下载管理器</span></a></li>
          <li><a href="<%= base_url %>admin/subscriptions" title="订阅管理器"><i class="fas fa-rss"></i><span>订阅管理器</span></a></li>
        <% end %>
      </ul>
      <div class="sidebar-search">
        <div class="sidebar-search-wrapper">
          <i class="fas fa-search sidebar-search-icon"></i>
          <input class="sidebar-search-input" type="search" placeholder="查找漫画..." aria-label="查找漫画">
        </div>
      </div>
      <div class="sidebar-toggle">
        <button onclick="toggleSidebar()" title="收起/展开侧栏">
          <i class="fas fa-chevron-left"></i>
        </button>
      </div>
      <div class="sidebar-footer">
        <a onclick="toggleTheme()" title="切换主题"><i class="fas fa-adjust"></i></a>
        <a href="<%= base_url %>logout" title="登出"><i class="fas fa-sign-out-alt"></i></a>
      </div>
    </nav>

    <!-- Main content (single render, responsive) -->
    <div class="app-content">
      <div id="alert"></div>
      <%= content %>
      <div id="totop-wrapper" x-data="{}" x-show="$('body').height() > 1.5 * $(window).height()">
        <a href="#" uk-totop uk-scroll></a>
      </div>
    </div>
    <script>
      setTheme();
      const base_url = "<%= base_url %>";

      // Sidebar toggle (collapse/expand)
      function toggleSidebar() {
        const sidebar = document.querySelector('.app-sidebar');
        const body = document.body;
        sidebar.classList.toggle('sidebar-collapsed');
        body.classList.toggle('sidebar-is-collapsed');
        localStorage.setItem('sidebar-collapsed', sidebar.classList.contains('sidebar-collapsed'));
      }

      // Restore sidebar state on load
      (function() {
        if (localStorage.getItem('sidebar-collapsed') === 'true') {
          document.querySelector('.app-sidebar').classList.add('sidebar-collapsed');
          document.body.classList.add('sidebar-is-collapsed');
        }
      })();

      // Sidebar search — filters .item elements on any page
      $(function(){
        var sidebarFilter = [];
        var sidebarResult = [];
        $('.uk-card-title').each(function(){
          sidebarFilter.push($(this).text());
        });
        $('.sidebar-search-input').on('keyup', function(){
          var input = $(this).val();
          if (input === '') {
            $('.item').each(function(){
              $(this).removeAttr('hidden');
            });
            $('#no-results').hide();
          } else {
            var regex = new RegExp(input, 'i');
            var visibleCount = 0;
            sidebarFilter.forEach(function(text, i){
              sidebarResult[i] = text.match(regex);
            });
            $('.item').each(function(i){
              if (sidebarResult[i]) {
                $(this).removeAttr('hidden');
                visibleCount++;
              } else {
                $(this).attr('hidden', '');
              }
            });
            if (visibleCount === 0 && $('#no-results').length) {
              $('#no-results').show();
            } else {
              $('#no-results').hide();
            }
          }
        });
      });
    </script>
    <%= render_component "uikit" %>
    <%= yield_content "script" %>
  </body>

</html>
